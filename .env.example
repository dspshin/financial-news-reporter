# Gemini API Key (https://aistudio.google.com/)
GEMINI_API_KEY=your_gemini_api_key_here

# Telegram configuration (https://core.telegram.org/bots)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHANNEL_ID=your_channel_id_here

# PEF Telegram configuration (optional)
# If TELEGRAM_PEF_BOT_TOKEN is omitted, TELEGRAM_BOT_TOKEN will be reused.
TELEGRAM_PEF_BOT_TOKEN=your_pef_bot_token_here
TELEGRAM_PEF_CHANNEL_ID=your_pef_channel_id_here

# PEF personalization (optional)
PEF_FIRM_NAME=Baikal Investment
PEF_PMI_ROLE=IT PMI Lead

# Logging configuration
LOG_FILE_PATH=latest_run.log
